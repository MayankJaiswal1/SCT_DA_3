          <manual-sort column='[federated.08deee71e08r931g6lrh30fqu1x3].[none:Calculation_3547318581051394:nk]' direction='ASC'>
            <dictionary>
              <bucket>&quot;Low&quot;</bucket>
              <bucket>&quot;Medium&quot;</bucket>
              <bucket>&quot;High&quot;</bucket>
              <bucket>&quot;Very High&quot;</bucket>
            </dictionary>
          </manual-sort>
          <aggregation value='true' />
        </view>
