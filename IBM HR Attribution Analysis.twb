              <calculation class='tableau' formula='IF [Attrition] = &quot;Yes&quot; THEN 1 ELSE 0 END' />
            </column>
            <column caption='Job Satisfaction Label' datatype='string' name='[Calculation_3547318581051394]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [JobSatisfaction]&#13;&#10;WHEN 1 THEN &quot;Low&quot;&#13;&#10;WHEN 2 THEN &quot;Medium&quot;&#13;&#10;WHEN 3 THEN &quot;High&quot;&#13;&#10;WHEN 4 THEN &quot;Very High&quot;&#13;&#10;END' />
            </column>
            <column caption='Job Satisfaction' datatype='integer' name='[JobSatisfaction]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_3547318580981761]' derivation='Avg' name='[avg:Calculation_3547318580981761:qk]' pivot='key' type='quantitative' />
